{
  "permissions": {
    "allow": [
      "Read(.tmp/**)",
      "Read(~/.claude/docs/**)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(gh api:*)",
      "Bash(gh pr view:*)",
      "Bash(git -C:*)",
      "Bash(git cherry:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git worktree add:*)",
      "Bash(git worktree list:*)",
      "Bash(go build:*)",
      "Bash(go clean:*)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(go list:*)",
      "Bash(go mod:*)",
      "Bash(go test:*)",
      "Bash(go version:*)",
      "Bash(go vet:*)",
      "Bash(golangci-lint:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xxd:*)"
    ],
    "defaultMode": "default"
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "verbose": true
}
